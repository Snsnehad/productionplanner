# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/transformer_mms

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# SMTP / Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password
EMAIL_FROM="Planning System <your_email@example.com>"

# Notification scheduling
PLAN_LOOKAHEAD_DAYS=2
REMINDER_INTERVAL_HOURS=2

# Frontend URL (used in email links, CORS)
FRONTEND_URL=http://localhost:5173

# Redis (BullMQ)
# Local:   redis://localhost:6379
# Upstash: rediss://default:PASSWORD@HOST.upstash.io:6379
REDIS_URL=redis://localhost:6379
