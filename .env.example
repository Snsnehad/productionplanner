# Used by docker-compose.yml — copy to .env in the project root and fill in.
# Anything left blank falls back to the default shown in docker-compose.yml.

# Redis
REDIS_URL=redis://localhost:6379

JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password
EMAIL_FROM="Planning System <your_email@example.com>"

PLAN_LOOKAHEAD_DAYS=2
REMINDER_INTERVAL_HOURS=2

# Browser-facing URL the frontend uses to call the backend API.
# Keep as localhost:5000 if running docker compose on your own machine.
VITE_API_URL=http://localhost:5000/api
FRONTEND_URL=http://localhost:5173
